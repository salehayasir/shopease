<% title = 'Login' %>
<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Welcome Back</h1>
      <p>Login to your account</p>
    </div>

    <% if (message) { %>
      <div class="alert alert-info"><p><%= message %></p></div>
    <% } %>

    <% if (errors.length > 0) { %>
      <div class="alert alert-error">
        <% errors.forEach(e => { %><p><%= e.msg %></p><% }) %>
      </div>
    <% } %>

    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Your password" required>
      </div>
      <button type="submit" class="btn-primary btn-lg btn-block">Login</button>
    </form>

    <p class="auth-switch">Don't have an account? <a href="/auth/register">Sign up free</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
