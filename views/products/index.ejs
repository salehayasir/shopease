<% title = 'Shop All Products' %>
<%- include('../partials/header') %>

<div class="page-header">
  <div class="container">
    <h1>All Products</h1>
    <p><%= products.length %> items</p>
  </div>
</div>

<div class="container shop-layout">
  <!-- Sidebar filters -->
  <aside class="shop-sidebar">
    <h3>Filter by Category</h3>
    <ul class="filter-list">
      <li><a href="/products" class="<%= !category ? 'active' : '' %>">All Products</a></li>
      <% categories.forEach(cat => { %>
        <li><a href="/products?category=<%= cat %>" class="<%= category === cat ? 'active' : '' %>"><%= cat %></a></li>
      <% }) %>
    </ul>

    <h3 style="margin-top: 2rem;">Sort by</h3>
    <ul class="filter-list">
      <li><a href="/products<%= category ? '?category=' + category : '' %>" class="<%= !sort ? 'active' : '' %>">Default</a></li>
      <li><a href="/products?<%= category ? 'category=' + category + '&' : '' %>sort=price-asc" class="<%= sort === 'price-asc' ? 'active' : '' %>">Price: Low to High</a></li>
      <li><a href="/products?<%= category ? 'category=' + category + '&' : '' %>sort=price-desc" class="<%= sort === 'price-desc' ? 'active' : '' %>">Price: High to Low</a></li>
      <li><a href="/products?<%= category ? 'category=' + category + '&' : '' %>sort=rating" class="<%= sort === 'rating' ? 'active' : '' %>">Top Rated</a></li>
    </ul>
  </aside>

  <!-- Products grid -->
  <main class="shop-main">
    <div class="product-grid">
      <% products.forEach(product => { %>
        <div class="product-card">
          <a href="/products/<%= product.slug %>">
            <div class="product-img-wrap">
              <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
            </div>
          </a>
          <div class="product-info">
            <span class="product-category"><%= product.category %></span>
            <h3><a href="/products/<%= product.slug %>"><%= product.name %></a></h3>
            <div class="product-meta">
              <span class="product-price">$<%= product.price.toFixed(2) %></span>
              <span class="product-rating">★ <%= product.rating %> (<%= product.reviews %>)</span>
            </div>
            <form action="/cart/add" method="POST">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="btn-add-cart">Add to Cart</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
    <% if (products.length === 0) { %>
      <div class="empty-state">
        <p>No products found in this category.</p>
        <a href="/products" class="btn-primary">View All</a>
      </div>
    <% } %>
  </main>
</div>

<%- include('../partials/footer') %>
